{
    "autoDocstringPy.customTemplatePath": ".vscode/docstring.mustache",
    "files.associations": {
        "*.f": "FortranFixedForm",
        "*.f90": "FortranFreeForm"
    },
    "[FortranFixedForm]": {
        "editor.rulers": [
            72
        ]
    },
    "python-envs.defaultEnvManager": "ms-python.python:conda",
    "python-envs.defaultPackageManager": "ms-python.python:conda"
}